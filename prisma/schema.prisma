generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Business {
  id        String   @id @default(cuid())
  name      String
  industry  String?
  website   String?
  country   String?
  status    String   @default("active")
  summary   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employments   Employment[]
  opportunities Opportunity[]
  evidence      Evidence[]
  timeline      TimelineEvent[]
  inboxItems    InboxItem[]
  notebookEntries NotebookEntry[]
  interactions    ContactInteraction[]
  pursuits        Pursuit[]
}

model Person {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  linkedinUrl String?
  email       String?
  phone       String?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employments Employment[]
  evidence    Evidence[]
  timeline    TimelineEvent[]
  interactions ContactInteraction[]
  pursuits     Pursuit[]
}

model Employment {
  id         String   @id @default(cuid())
  personId   String
  businessId String

  jobTitle   String?
  startDate  DateTime?
  endDate    DateTime?
  isCurrent  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  person   Person   @relation(fields: [personId], references: [id])
  business Business @relation(fields: [businessId], references: [id])
}

model Opportunity {
  id             String   @id @default(cuid())
  businessId     String
  title          String
  status         String   @default("open")
  estimatedValue Int?
  nextAction     String?
  summary        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id])
}

model Evidence {
  id         String   @id @default(cuid())
  businessId String?
  personId   String?

  type       String
  title      String?
  content    String
  source     String?
  capturedAt DateTime @default(now())

  business Business? @relation(fields: [businessId], references: [id])
  person   Person?   @relation(fields: [personId], references: [id])
}

model TimelineEvent {
  id         String   @id @default(cuid())
  businessId String?
  personId   String?

  eventType  String
  summary    String
  occurredAt DateTime @default(now())

  business Business? @relation(fields: [businessId], references: [id])
  person   Person?   @relation(fields: [personId], references: [id])
}

model InboxItem {
  id         String   @id @default(cuid())
  businessId String?

  type      String
  status    String   @default("pending")
  title     String
  summary   String?
  payload   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business? @relation(fields: [businessId], references: [id])
}
model NotebookEntry {
  id         String   @id @default(cuid())

  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  content    String

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ContactInteraction {
  id           String   @id @default(cuid())

  personId      String
  person        Person   @relation(fields: [personId], references: [id])

  businessId    String
  business      Business @relation(fields: [businessId], references: [id])

  pursuitId     String?
  pursuit       Pursuit? @relation(fields: [pursuitId], references: [id])

  type          String
  channel       String   @default("LinkedIn")
  summary       String
  messageText   String?
  aiNotes       String?

  occurredAt    DateTime @default(now())

  createdAt     DateTime @default(now())
}

model Pursuit {
  id                String   @id @default(cuid())

  personId          String
  person            Person   @relation(fields: [personId], references: [id])

  businessId        String
  business          Business @relation(fields: [businessId], references: [id])

  stage             String   @default("Found")
  priority          String   @default("Medium")
  source            String   @default("LinkedIn")
  whyRelevant       String?
  storeLabAngle     String?
  currentStatus     String?
  nextAction        String?
  nextActionDueAt   DateTime?
  teaserVideoSent   Boolean  @default(false)
  lastInteractionAt DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  interactions      ContactInteraction[]

  @@index([businessId])
  @@index([personId])
  @@index([stage])
}
